# Salin file ini menjadi .env lalu isi sesuai koneksi database kamu.
# JANGAN commit file .env ke GitHub!

# Untuk pgAdmin/PostgreSQL lokal:
DATABASE_URL=postgresql://postgres:password_kamu@localhost:5432/db_akademik

# Untuk deployment (Railway/Render/Neon/Supabase) nanti nilai ini akan
# diisi lewat dashboard hosting, bukan lewat file .env.

SECRET_KEY=ganti_dengan_string_acak_yang_panjang
